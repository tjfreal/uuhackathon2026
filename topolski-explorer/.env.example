# Topolski Explorer — Environment Configuration
# Copy this file to .env and fill in your values.

# OpenAI API Key (required for transcription, embedding, and reranking)
OPENAI_API_KEY=sk-...

# OpenAI models — override if needed
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_RERANK_MODEL=gpt-4o
ENABLE_RERANK=false

# Collection source (public — no credentials needed)
ITEM_DETAILS_BASE_URL=https://collections.lib.utah.edu/details?id=
COLLECTION_SEARCH_URL=https://collections.lib.utah.edu/search?facet_setname_s=
COLLECTION_FACET_SETNAME=uum_tc
COLLECTION_NAME=Topolski Chronicles

# Local data paths (gitignored — these are generated, not committed)
RAW_DATA_DIR=staged_data_raw
STAGED_DATA_DIR=data/staged
CHROMA_DB_PATH=data/chroma
CHROMA_COLLECTION_NAME=topolski_explorer

# Pipeline tuning
# Max items to process during a run (unset = process all)
# Set to e.g. 10 for a quick demo-sized index
MAX_ITEMS=

# Image resolution for GPT-4o vision calls (pixels on long edge)
# 1568 is GPT-4o's high-detail optimum. Lower = faster + cheaper, worse HTR.
PAGE_IMAGE_LONG_EDGE=1568
OPENAI_VISION_MAX_TOKENS=2500
OPENAI_API_DELAY_SECONDS=0.5
EMBED_BATCH_SIZE=96
RETRIEVAL_K=30
PAGE_CANDIDATE_LIMIT=12
RESULTS_TO_SHOW=8

# Flask
FLASK_PORT=5050
FLASK_DEBUG=true
